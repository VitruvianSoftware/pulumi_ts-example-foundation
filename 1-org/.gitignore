# Node.js
node_modules/
package-lock.json
dist/

# TypeScript compiled output
*.js
*.js.map
*.d.ts

# Preserve Cloud Function source files that must ship with the deployment.
# The CAI monitoring function is plain JS (not compiled from TS), so it must
# be tracked even though *.js is globally ignored above.
!cai-monitoring-function/**/*.js

# Pulumi stack configs (contain secrets / environment-specific values)
Pulumi.*.yaml
!Pulumi.yaml
!Pulumi.*.yaml.example
!cai-monitoring-function/**/*.js

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temporary
tmp_plan/
*.log

# Credentials
credentials.json
.envrc
