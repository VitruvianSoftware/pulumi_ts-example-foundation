/**
 * 4-projects/business_unit_1/shared/example_infra_pipeline.ts.example
 * Mirrors: terraform-example-foundation/4-projects/business_unit_1/shared/example_infra_pipeline.tf
 * Provides an example implementation of the infra_pipelines module for Cloud Build
 * to maintain architectural parity with the Terraform foundation.
 */

import * as pulumi from "@pulumi/pulumi";
import * as gcp from "@pulumi/gcp";
import { ProjectFactory } from "@vitruviansoftware/foundation-project-factory";

export = async () => {
    const config = new pulumi.Config();
    const bootstrapRef = new pulumi.StackReference("bootstrap");

    const cloudbuildProjectId = bootstrapRef.getOutput("cloudbuild_project_id") as pulumi.Output<string>;
    const defaultRegion = config.require("default_region");
    const projectPrefix = config.get("project_prefix") || "prj";
    const businessCode = config.get("business_code") || "bu1";
    const orgId = config.require("org_id");
    const billingAccount = config.require("billing_account");

    const appInfraRepos = ["bu1-example-app"];

    // App-infra Cloud Build project
    const appInfraProject = new ProjectFactory("app-infra-pipeline", {
        name: `${projectPrefix}-c-${businessCode}-infra-pipeline`,
        orgId: orgId,
        billingAccount: billingAccount,
        folderId: config.require("common_folder_name"),
        deletionPolicy: config.get("project_deletion_policy") || "PREVENT",
        activateApis: [
            "cloudbuild.googleapis.com",
            "cloudresourcemanager.googleapis.com",
            "iam.googleapis.com",
            "billingbudgets.googleapis.com",
            "artifactregistry.googleapis.com",
        ],
        labels: {
            environment: "common",
            application_name: `${businessCode}-infra-pipeline`,
            billing_code: "1234",
            primary_contact: "example1",
            secondary_contact: "example2",
            business_code: businessCode,
            env_code: "c",
            vpc: "none",
        },
    });

    const tfCbBuilderSa = new gcp.serviceaccount.Account("tf-cb-builder-sa", {
        accountId: "tf-cb-builder-sa",
        project: cloudbuildProjectId,
    });

    const buildRoles = [
        "roles/storage.objectAdmin",
        "roles/cloudbuild.builds.builder",
    ];

    buildRoles.forEach((role, i) => {
        new gcp.projects.IAMMember(`build-role-${i}`, {
            project: cloudbuildProjectId,
            role: role,
            member: pulumi.interpolate`serviceAccount:${tfCbBuilderSa.email}`,
        });
    });

    // Cloud Source Repositories
    const repos: Record<string, gcp.sourcerepo.Repository> = {};
    for (const repoName of appInfraRepos) {
        repos[repoName] = new gcp.sourcerepo.Repository(`app-infra-repo-${repoName}`, {
            name: repoName,
            project: cloudbuildProjectId,
        });
    }

    new gcp.sourcerepo.Repository("gcp-policies", {
        name: "gcp-policies",
        project: cloudbuildProjectId,
    });

    // Cloud Build Bucket
    const cloudbuildBucketName = pulumi.interpolate`${cloudbuildProjectId}_cloudbuild`;
    new gcp.storage.Bucket("cloudbuild-bucket", {
        name: cloudbuildBucketName,
        project: cloudbuildProjectId,
        location: defaultRegion,
        uniformBucketLevelAccess: true,
        forceDestroy: true,
        versioning: {
            enabled: true,
        },
    });

    // TF Workspace simulation (since we don't have tf_cloudbuild_workspace module ported)
    // We create SAs, buckets, and triggers for each repo
    const workspaceSas: Record<string, gcp.serviceaccount.Account> = {};
    const logBuckets: Record<string, gcp.storage.Bucket> = {};
    const stateBuckets: Record<string, gcp.storage.Bucket> = {};
    const artifactsBuckets: Record<string, gcp.storage.Bucket> = {};

    for (const repoName of appInfraRepos) {
        workspaceSas[repoName] = new gcp.serviceaccount.Account(`sa-tf-cb-${repoName}`, {
            accountId: `sa-tf-cb-${repoName}`,
            project: cloudbuildProjectId,
        });

        const prefix = config.get("bucket_prefix") || "bkt";
        stateBuckets[repoName] = new gcp.storage.Bucket(`state-${repoName}`, {
            name: pulumi.interpolate`${prefix}-${cloudbuildProjectId}-${repoName}-state`,
            project: cloudbuildProjectId,
            location: defaultRegion,
            uniformBucketLevelAccess: true,
            forceDestroy: true,
            versioning: { enabled: true },
        });

        logBuckets[repoName] = new gcp.storage.Bucket(`logs-${repoName}`, {
            name: pulumi.interpolate`${prefix}-${cloudbuildProjectId}-${repoName}-logs`,
            project: cloudbuildProjectId,
            location: defaultRegion,
            uniformBucketLevelAccess: true,
            forceDestroy: true,
        });

        artifactsBuckets[repoName] = new gcp.storage.Bucket(`artifacts-${repoName}`, {
            name: pulumi.interpolate`${prefix}-${cloudbuildProjectId}-${repoName}-artifacts`,
            project: cloudbuildProjectId,
            location: defaultRegion,
            uniformBucketLevelAccess: true,
            forceDestroy: true,
        });

        // Add IAM permissions
        new gcp.storage.BucketIAMMember(`cloudbuild-storage-read-${repoName}`, {
            bucket: logBuckets[repoName].name,
            role: "roles/storage.admin",
            member: pulumi.interpolate`serviceAccount:${appInfraProject.serviceAccountEmail}`,
        });

        new gcp.storage.BucketIAMMember(`cloudbuild-sa-storage-admin-${repoName}`, {
            bucket: logBuckets[repoName].name,
            role: "roles/storage.admin",
            member: pulumi.interpolate`serviceAccount:${tfCbBuilderSa.email}`,
        });
    }

    new gcp.projects.IAMMember("workload-identity-admin", {
        project: appInfraProject.projectId,
        role: "roles/iam.workloadIdentityPoolAdmin",
        member: pulumi.interpolate`serviceAccount:${appInfraProject.serviceAccountEmail}`,
    });

    return {
        app_infra_pipeline_project_id: appInfraProject.projectId,
        default_region: defaultRegion,
        cloudbuild_sa: workspaceSas[appInfraRepos[0]].email,
        cloudbuild_bucket: cloudbuildBucketName,
        source_repos: repos[appInfraRepos[0]].name,
        log_buckets: logBuckets[appInfraRepos[0]].name,
        state_buckets: stateBuckets[appInfraRepos[0]].name,
        artifacts_buckets: artifactsBuckets[appInfraRepos[0]].name,
    };
};
